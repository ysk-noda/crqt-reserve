# Supabase の設定
# Supabase ダッシュボード → Settings → API から取得
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx

# 管理者画面のパスワード（/admin にアクセス時に使用）
VITE_ADMIN_PASSWORD=your-secure-password

# ----------------------------------------------------------------
# 以下は Supabase Edge Function のシークレット（.envには不要）
# Supabase ダッシュボード → Edge Functions → Secrets で設定
# ----------------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxxxxxx          ← Resend で取得
# RESEND_FROM_EMAIL=noreply@yourdomain.com ← 送信元アドレス
